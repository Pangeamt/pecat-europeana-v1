generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId], map: "accounts_userId_fkey")
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "sessions_userId_fkey")
  @@map("sessions")
}

model User {
  id            String     @id @default(cuid())
  name          String
  email         String     @unique
  salt          String?
  hash          String?
  emailVerified DateTime?
  image         Bytes?
  role          Role       @default(USER)
  provider      String?
  workspaceId   String?
  deletedAt     DateTime?
  accounts      Account[]
  projects      Project[]
  sessions      Session[]
  workspace     Workspace? @relation("WorkspaceMembers", fields: [workspaceId], references: [id])
  createdTms    Tm[]       @relation("TmCreatedBy")

  @@index([workspaceId], map: "users_workspaceId_fkey")
  @@index([deletedAt], map: "users_deletedAt_idx")
  @@map("users")
}

model Workspace {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  members   User[]    @relation("WorkspaceMembers")
  projects  Project[]
  tms       Tm[]

  @@map("workspaces")
}

model Project {
  id             String    @id @default(cuid())
  label          String?
  filename       String
  filePath       String
  uuid           String?   @unique
  accessDeadline DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  userId         String
  workspaceId    String
  deletedAt      DateTime?
  mt             Boolean   @default(false)
  tmMode         String    @default("standart")
  tmThreshold    Int       @default(0)
  extension      String    @default("json")
  sourceLanguage String?
  targetLanguage String?
  exampleXml     String?
  status         ProjectStatus @default(UPLOADED)
  User           User      @relation(fields: [userId], references: [id])
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  tus            Tu[]
  projectTms     ProjectTm[]

  @@index([userId], map: "projects_userId_fkey")
  @@index([workspaceId], map: "projects_workspaceId_fkey")
  @@map("projects")
}

model Tu {
  id                      String   @id @default(cuid())
  externalId              String?
  translationLiteralId    Int?
  translationId           Int?
  count                   Int?
  fieldName               String?
  shortFieldname          String?
  srcLiteral              String   @db.Text
  translatedLiteral       String?  @db.Text
  reviewLiteral           String?  @db.Text
  sourceLanguage          String
  targetLanguage          String
  translationScorePercent Float?
  tmInfo                  Json?
  createdAt               DateTime @default(now())
  exampleXml              String?  @db.VarChar(500)
  updatedAt               DateTime @updatedAt
  Status                  Status   @default(NOT_REVIEWED)
  projectId               String?
  levenshteinDistance     Float?
  belongTo                String?
  Project                 Project? @relation(fields: [projectId], references: [id])

  @@index([projectId], map: "tus_projectId_fkey")
  @@map("tus")
}

model Tm {
  id              String    @id @default(cuid())
  name            String
  domain          String?
  sourceLanguage  String
  targetLanguage  String
  createdByUserId String
  workspaceId     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  createdBy       User      @relation("TmCreatedBy", fields: [createdByUserId], references: [id])
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  projectTms      ProjectTm[]

  @@index([workspaceId], map: "tms_workspaceId_fkey")
  @@index([createdByUserId], map: "tms_createdByUserId_fkey")
  @@index([deletedAt], map: "tms_deletedAt_idx")
  @@map("tms")
}

model ProjectTm {
  projectId String
  tmId      String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tm      Tm      @relation(fields: [tmId], references: [id], onDelete: Cascade)

  @@id([projectId, tmId])
  @@index([tmId], map: "project_tms_tmId_idx")
  @@map("project_tms")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum Role {
  SUPER
  ADMIN
  USER
}

enum Status {
  EDITED
  ACCEPTED
  TRANSLATED_MT
  NOT_REVIEWED
  REJECTED
}

enum ProjectStatus {
  UPLOADED
  PROCESSING
  OXIGEN_PROCESSING
  MTQE_PROCESSING
  READY
  OXIGEN_ERROR
  MTQE_ERROR
}
